#include <iostream>
#include <vector>
#include <unordered_map>
#include <unordered_set>
#include <queue>
using namespace std;

// LeetCode 355: Design Twitter
class Twitter {
private:
    int timestamp;
    // userId -> list of {timestamp, tweetId}
    unordered_map<int, vector<pair<int,int>>> tweets;
    // userId -> set of followeeIds
    unordered_map<int, unordered_set<int>> following;

public:
    Twitter() : timestamp(0) {}

    void postTweet(int userId, int tweetId) {
        tweets[userId].push_back({timestamp++, tweetId});
    }

    vector<int> getNewsFeed(int userId) {
        // Max-heap: {timestamp, tweetId}
        priority_queue<pair<int,int>> pq;

        // Own tweets
        for (auto& t : tweets[userId])
            pq.push(t);

        // Followed users tweets
        for (int followee : following[userId])
            for (auto& t : tweets[followee])
                pq.push(t);

        vector<int> feed;
        while (!pq.empty() && feed.size() < 10) {
            feed.push_back(pq.top().second);
            pq.pop();
        }
        return feed;
    }

    void follow(int followerId, int followeeId) {
        if (followerId != followeeId)
            following[followerId].insert(followeeId);
    }

    void unfollow(int followerId, int followeeId) {
        following[followerId].erase(followeeId);
    }
};

int main() {
    cout << "=== LeetCode 355: Design Twitter ===" << endl;

    Twitter tw;
    tw.postTweet(1, 5);

    auto feed = tw.getNewsFeed(1);
    cout << "getNewsFeed(1): [";
    for (int i = 0; i < feed.size(); i++) cout << (i?", ":"") << feed[i];
    cout << "] (expected: [5])" << endl;

    tw.follow(1, 2);
    tw.postTweet(2, 6);

    feed = tw.getNewsFeed(1);
    cout << "getNewsFeed(1) after follow+tweet: [";
    for (int i = 0; i < feed.size(); i++) cout << (i?", ":"") << feed[i];
    cout << "] (expected: [6, 5])" << endl;

    tw.unfollow(1, 2);
    feed = tw.getNewsFeed(1);
    cout << "getNewsFeed(1) after unfollow: [";
    for (int i = 0; i < feed.size(); i++) cout << (i?", ":"") << feed[i];
    cout << "] (expected: [5])" << endl;

    cout << "\n--- Test: multiple tweets, top 10 ---" << endl;
    Twitter tw2;
    for (int i = 1; i <= 12; i++) tw2.postTweet(1, i);
    feed = tw2.getNewsFeed(1);
    cout << "getNewsFeed(1) [12 tweets, shows top 10]: [";
    for (int i = 0; i < feed.size(); i++) cout << (i?", ":"") << feed[i];
    cout << "]" << endl;

    return 0;
}
