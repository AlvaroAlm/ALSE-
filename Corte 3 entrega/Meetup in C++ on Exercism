#pragma once
#include <string>
#include <stdexcept>

namespace meetup {

inline int answer(int year, int month, const std::string& week, const std::string& day_of_week) {
    const std::string days[] = {"Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"};
    int target_dow = -1;
    for (int i = 0; i < 7; i++) {
        if (days[i] == day_of_week) { target_dow = i; break; }
    }
    if (target_dow == -1) throw std::invalid_argument("Invalid day");

    int dim;
    if (month == 2) {
        bool leap = (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
        dim = leap ? 29 : 28;
    } else if (month == 4 || month == 6 || month == 9 || month == 11) {
        dim = 30;
    } else {
        dim = 31;
    }

    auto dow = [](int y, int m, int d) -> int {
        static int t[] = {0,3,2,5,0,3,5,1,4,6,2,4};
        if (m < 3) y--;
        return (y + y/4 - y/100 + y/400 + t[m-1] + d) % 7;
    };

    if (week == "teenth") {
        for (int d = 13; d <= 19; d++)
            if (dow(year, month, d) == target_dow) return d;
    } else if (week == "last") {
        for (int d = dim; d >= dim - 6; d--)
            if (dow(year, month, d) == target_dow) return d;
    } else {
        int nth = (week == "first") ? 1 : (week == "second") ? 2 :
                  (week == "third") ? 3 : 4;
        int count = 0;
        for (int d = 1; d <= dim; d++)
            if (dow(year, month, d) == target_dow && ++count == nth) return d;
    }
    throw std::logic_error("No such day found");
}

} // namespace meetup
