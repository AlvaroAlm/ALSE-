#include <iostream>
#include <vector>

using namespace std;

class ATM {
private:
    long long counts[5];
    int denoms[5] = {20, 50, 100, 200, 500};

public:
    ATM() {
        fill(counts, counts + 5, 0LL);
    }

    void deposit(vector<int> banknotesCount) {
        for (int i = 0; i < 5; i++)
            counts[i] += banknotesCount[i];
    }

    vector<int> withdraw(int amount) {
        vector<int> result(5, 0);
        int rem = amount;
        for (int i = 4; i >= 0; i--) {
            long long use = min((long long)(rem / denoms[i]), counts[i]);
            result[i] = (int)use;
            rem -= use * denoms[i];
        }
        if (rem != 0) return {-1};
        for (int i = 0; i < 5; i++)
            counts[i] -= result[i];
        return result;
    }
};

int main() {
    ATM atm;
    atm.deposit({0,0,1,2,1});
    auto r1 = atm.withdraw(600);
    cout << "withdraw(600): [";
    for (int i = 0; i < 5; i++) cout << r1[i] << (i<4?",":"");
    cout << "]" << endl;

    atm.deposit({0,1,0,1,1});
    auto r2 = atm.withdraw(600);
    cout << "withdraw(600): [";
    for (int i = 0; i < 5; i++) cout << r2[i] << (i<4?",":"");
    cout << "]" << endl;

    auto r3 = atm.withdraw(550);
    cout << "withdraw(550): [";
    for (int i = 0; i < 5; i++) cout << r3[i] << (i<4?",":"");
    cout << "]" << endl;
    return 0;
}
